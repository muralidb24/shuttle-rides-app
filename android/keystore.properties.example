# Copy to keystore.properties (gitignored) and fill in real values. Never
# commit the actual keystore.properties or .jks file - losing this signing
# key means you can never publish an update under the same app identity
# again, and leaking it means anyone could sign a malicious "update" that
# Android would trust.
storeFile=shuttle-rides-release.jks
storePassword=REPLACE_ME
keyAlias=shuttle-rides
keyPassword=REPLACE_ME
